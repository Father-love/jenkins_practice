pipeline {
    agent any
    stages {
        stage('checkout') {
            steps {
                echo "clone the code"
            }
        }
        stage("build") {
            steps {
                echo "buld the code"
            }
        }
        stage("test") {
            steps {
                echo "test the code"
            }
        }
        stage("deploy") {
            steps {
                echo "deploy the application"
            }
        }
    }
}